# 本地版（clip.sh）配置模板 —— 复制为 clip.env，按需改值，运行前 source：
#   cp clip.env.example clip.env && vim clip.env
#   set -a; . ./clip.env; set +a
#   clip.sh --file <mp4>
# clip.sh 全部用环境变量驱动，未设的项走下面注释里的默认值（`clip.sh --help` 列全）。

# ---- 路径（最常改）----
VAULT="$HOME/Obsidian/Vault/Inbox"      # Obsidian 收件夹，笔记落盘即收录（必改成你的库）
WXD_DOWNLOAD_DIR="$HOME/Downloads"      # 下载器 config.yaml 的 download.dir；--last 从这里取最新 mp4
# INBOX="$HOME/VideoInbox"              # 中转目录（默认 ~/VideoInbox）

# ---- ASR 后端 ----
ASR_BACKEND=sensevoice                  # sensevoice(本地离线,默认) | dashscope(云端百炼) | mlxwhisper
ASR_LANGUAGE=zh                         # 中英混说可设 auto
# DASHSCOPE_ENV_FILE="$HOME/.dashscope.env"   # 仅 ASR_BACKEND=dashscope 时：含 DASHSCOPE_API_KEY 的 .env

# ---- 视觉理解 ----
VISUAL_MODE=both                        # both(音频+视觉,默认) | audio(仅ASR) | visual(仅画面)
VLM_BACKEND=ollama                      # ollama(默认,模型保温) | mlx
VLM_MODEL=qwen3-vl:30b-a3b              # 本地 VLM；不可用时自动降级为只 OCR
VISUAL_MAX_FRAMES=60                    # 关键帧上限
SAMPLE_FPS=1                            # 抽帧帧率（再经 mpdecimate 确定性去重）

# ---- 快路径（可选，需先按 SETUP.md §C 部署 Cloudflare Worker）----
SPH_API=                                # 已部署的视频号查询 Worker 地址 https://<名>.<子域>.workers.dev；留空=关闭快路径

# clip-server 主配置 —— 复制为 clip.env 并填入真实值（clip.env 不进 git）
# 由 systemd 的 clip-server.service 以 EnvironmentFile 加载；本地直接跑可 `set -a; . clip.env; set +a`

# ---- 视频号解析（二选一）----
SPH_API=                                # 用 Cloudflare Worker 解析时填其地址；用本地解析(sph_cookie.env)则留空
PARSE_PATH=/api/fetch_video_profile     # Worker 的解析接口路径（默认即可）

# ---- 百炼 DashScope（必填）----
DASHSCOPE_API_KEY=sk-xxxxxxxxxxxx        # 阿里云百炼 API Key
DASHSCOPE_MODEL_ASR=paraformer-realtime-v2   # 语音识别模型
DASHSCOPE_MODEL_VL=qwen-vl-max          # 视觉理解模型
DASHSCOPE_MODEL_TEXT=qwen-max           # 摘要模型

# ---- 写入 Obsidian ----
MCP_URL=http://127.0.0.1:8787/mcp       # obsidian-sync-mcp 地址（见 osmcp.env.example）
VAULT_FOLDER=wx_video                   # 默认写入的文件夹

# ---- 接口鉴权（必填）----
CLIP_API_TOKEN=change-me-to-a-random-token   # /clip 接口 token，自取随机串

# ---- 抽帧/视觉调参（可选，留默认即可）----
VISUAL_MODE=both                        # both | audio | visual
SAMPLE_FPS=1                            # 抽帧帧率
MPDECIMATE=hi=64*48:lo=64*16:frac=0.02  # mpdecimate 去重灵敏度
VISUAL_MAX_FRAMES=60                    # 关键帧上限
VL_CONCURRENCY=6                        # 并发调 qwen-vl 的帧数（内存紧可调小）

# ---- 钉钉 / 企业微信 ----
# 通知与入站接收的配置分别在 ding.env.example / wx.env.example，按需复制启用

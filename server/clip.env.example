# clip-server 主配置 —— 复制为 clip.env 并填入真实值（clip.env 不进 git）
SPH_API=                                # 可选：Cloudflare Worker 地址；若用本地解析(sph_cookie.env)则留空
PARSE_PATH=/api/fetch_video_profile
DASHSCOPE_API_KEY=sk-xxxxxxxxxxxx        # 阿里云百炼 API Key
DASHSCOPE_MODEL_VL=qwen-vl-max          # 视觉模型
DASHSCOPE_MODEL_TEXT=qwen-max           # 摘要模型
VAULT_FOLDER=wx_video                   # 默认写入 Obsidian 的文件夹
MCP_URL=http://127.0.0.1:8787/mcp       # obsidian-sync-mcp 地址
VISUAL_MODE=both                        # both | audio | visual
VL_CONCURRENCY=6                        # 并发调 qwen-vl 的帧数
CLIP_API_TOKEN=change-me-to-a-random-token   # /clip 接口鉴权

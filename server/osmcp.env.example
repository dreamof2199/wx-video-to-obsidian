# obsidian-sync-mcp 配置（LiveSync 写入后端）—— 复制为 osmcp.env 填真实值
COUCHDB_URL=https://your-couchdb.example.com
COUCHDB_USER=your_user
COUCHDB_PASSWORD=your_password
COUCHDB_DATABASE=obsidiannotes
COUCHDB_PASSPHRASE=your-e2e-passphrase        # LiveSync 端到端加密口令（与 Obsidian 设置一致）
COUCHDB_OBFUSCATE_PROPERTIES=true             # 与 LiveSync "Obfuscate Properties" 一致
VAULT_NAME=Your Obsidian Vault
HOST=127.0.0.1
PORT=8787
